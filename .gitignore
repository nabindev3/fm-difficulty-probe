# Data & artifacts (staged from legacy extraction; large, not version-controlled).
# data/ keeps only its README; everything else there is symlinks/tensors.
data/*
!data/README.md

# results/: the small JSON summaries and markdown tables ARE committed — they are
# the reference the paper's numbers and the Phase-2 regression gate diff against.
# Heavy per-item artifacts (parquet/npz/png) stay out.
results/**
!results/**/
!results/**/*.json
!results/**/*.md
*.safetensors
*.parquet
*.pt
*.npz

# Legacy repos imported for reference; delete before submission
_legacy/

# Python
__pycache__/
*.pyc
.venv/
venv/
.pytest_cache/

# Editable-install / build artifacts
*.egg-info/
build/
dist/

# Editor / IDE state (not shared across machines)
.vscode/
.idea/

# OS
.DS_Store

# LaTeX build intermediates
paper/*.aux
paper/*.log
paper/*.blg
paper/*.bbl
paper/*.out
paper/*.synctex.gz
